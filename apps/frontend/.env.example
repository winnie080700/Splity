# Optional public API origin. Leave unset to use same-origin `/api` requests.
# Example for a separately hosted backend:
# VITE_API_BASE_URL=https://api.example.com

# Local Vite dev proxy target used for `/api` and `/health`.
# Keep this in sync with apps/backend/src/Splity.Api/Properties/launchSettings.json
VITE_DEV_API_PROXY_TARGET=http://localhost:5204

# Optional extra hosts allowed by Vite dev server.
# Useful for Cloudflare Quick Tunnel or other reverse proxies.
# VITE_DEV_ALLOWED_HOSTS=.trycloudflare.com
